# ~/.zsh_aliases — zsh-native equivalents of ~/.bash_aliases

# Tools (claude, codex, cswap, uv) install into ~/.local/bin
case ":$PATH:" in *":$HOME/.local/bin:"*) ;; *) export PATH="$HOME/.local/bin:$PATH" ;; esac

export PAGER="less -R"
export EDITOR="vim"

# EDITOR=vim makes zsh pick the vi-insert keymap, where ^P/^N self-insert
# instead of navigating history. Rebind them while keeping vi mode.
bindkey -M viins '^P' up-line-or-history
bindkey -M viins '^N' down-line-or-history

# Incremental history search. Ctrl+S is XOFF (flow-control freeze) in most
# terminals, so disable that or forward-search never reaches zsh.
bindkey -M viins '^R' history-incremental-search-backward
bindkey -M viins '^S' history-incremental-search-forward
[[ -o interactive ]] && stty -ixon 2>/dev/null

# History
export HISTSIZE=10000
export SAVEHIST=10000
export HISTFILE="$HOME/.zsh_history"
setopt APPEND_HISTORY
setopt HIST_IGNORE_DUPS

# Colors (BSD/macOS ls via CLICOLOR; GNU/Linux ls via --color)
export CLICOLOR=1
export LSCOLORS="Exgxcxdxcxegedabagacad"
if ls --color=auto >/dev/null 2>&1; then
    alias ls='ls --color=auto'
fi

# Prompt with git branch (zsh equivalent of the bash PS1)
autoload -Uz vcs_info
zstyle ':vcs_info:git:*' formats ' (%b)'
precmd() { vcs_info }
setopt PROMPT_SUBST
PROMPT='%F{green}[%f %n@%m:%F{blue}%~%F{yellow}${vcs_info_msg_0_}%f %F{green}]%f '

alias less="less -R"
alias jq="jq -C"
jctl()   { cat "$1" | jq | less ; }
jctlip() { local tmp=$(mktemp) && sed 's/\x1b\[[0-9;]*m//g' "$1" | command jq . > "$tmp" && mv "$tmp" "$1"; }
mem()    { ps -eo rss,pid,euser,args:100 --sort %mem | grep -v grep | grep -i "$@" | awk '{printf $1/1024 "MB"; $1=""; print }'; }
